                        <category domain="https://www.pbs.org/newshour/tag/political-division"><![CDATA[political division]]></category>
                                                        <dc:creator><![CDATA[Liz Landers]]></dc:creator>
                                <dc:creator><![CDATA[Doug Adams]]></dc:creator>
