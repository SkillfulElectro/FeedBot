		<link>https://news.bitcoin.com/stefan-muehlbauer-warns-doj-indictments-end-safe-zone-as-us-army-sergeant-case-expands-risk/</link>
		
		<dc:creator><![CDATA[Terence Zimwara]]></dc:creator>
