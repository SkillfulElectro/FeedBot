    <item>
      <title>آستان شیخ صدوق؛ پایگاهی فرهنگی ری در قبله تهران است</title>
      <link>https://www.irna.ir/news/86143261/%D8%A2%D8%B3%D8%AA%D8%A7%D9%86-%D8%B4%DB%8C%D8%AE-%D8%B5%D8%AF%D9%88%D9%82-%D9%BE%D8%A7%DB%8C%DA%AF%D8%A7%D9%87%DB%8C-%D9%81%D8%B1%D9%87%D9%86%DA%AF%DB%8C-%D8%B1%DB%8C-%D8%AF%D8%B1-%D9%82%D8%A8%D9%84%D9%87-%D8%AA%D9%87%D8%B1%D8%A7%D9%86-%D8%A7%D8%B3%D8%AA</link>
