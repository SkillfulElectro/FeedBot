    <item>
      <title>Why I Sought Out a Taliban Commander I Had Fought</title>
      <link>https://www.nytimes.com/2026/07/23/world/asia/taliban-afghanistan-marine.html</link>
      <guid isPermaLink="true">https://www.nytimes.com/2026/07/23/world/asia/taliban-afghanistan-marine.html</guid>
