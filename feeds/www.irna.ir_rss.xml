      <category domain="energy_oil">نفت و انرژی</category>
      <pubDate>Tue, 05 May 2026 13:49:46 GMT</pubDate>
      <guid>https://www.irna.ir/news/86146555/%D9%87%D8%B4%D8%AF%D8%A7%D8%B1-%D9%85%D8%B9%D8%A7%D9%88%D9%86-%D8%B1%D8%A6%DB%8C%D8%B3-%D8%AC%D9%85%D9%87%D9%88%D8%B1-%D8%AF%D8%B1%D8%A8%D8%A7%D8%B1%D9%87-%D8%B3%D8%A7%D9%84-%D8%B3%D8%AE%D8%AA-%D8%A7%D9%86%D8%B1%DA%98%DB%8C-%D8%A8%D8%B1%D9%86%D8%A7%D9%85%D9%87-%D8%AF%D9%88%D9%84%D8%AA-%D8%A8%D8%B1%D8%A7%DB%8C</guid>
