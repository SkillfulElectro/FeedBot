      <link>https://www.irna.ir/news/86148625/%D8%B5%D9%86%D8%AF%D9%88%D9%82-%D8%A8%DB%8C%D9%85%D8%A7%D8%B1%DB%8C-%D9%87%D8%A7%DB%8C-%D8%AE%D8%A7%D8%B5-%D9%88-%D8%B5%D8%B9%D8%A8-%D8%A7%D9%84%D8%B9%D9%84%D8%A7%D8%AC-%DA%AF%D8%A7%D9%85%DB%8C-%D8%A8%D8%B1%D8%A7%DB%8C-%DA%A9%D8%A7%D9%87%D8%B4-%D9%BE%D8%B1%D8%AF%D8%A7%D8%AE%D8%AA-%D8%A7%D8%B2-%D8%AC%DB%8C%D8%A8</link>
      <description>تهران - ایرنا-مدیرکل بیمه سلامت استان تهران از پوشش بیش از ۱۳۰ گروه بیماری در صندوق بیماری‌های خاص و صعب‌العلاج خبر داد و گفت: این صندوق با هدف حمایت از بیماران مبتلا به بیماری‌های نادر، خاص و صعب‌العلاج و کاهش هزینه‌های درمانی آنان، از نیمه دوم سال ۱۴۰۱ فعالیت خود را آغاز کرده است.</description>
      <content:encoded />
      <enclosure url="https://img9.irna.ir/d/r2/2026/04/07/4/172796856.jpg" length="1024000" type="image/jpeg" />
      <category domain="tehran">استان‌ها &gt; تهران</category>
      <pubDate>Fri, 08 May 2026 11:09:55 GMT</pubDate>
      <guid>https://www.irna.ir/news/86148625/%D8%B5%D9%86%D8%AF%D9%88%D9%82-%D8%A8%DB%8C%D9%85%D8%A7%D8%B1%DB%8C-%D9%87%D8%A7%DB%8C-%D8%AE%D8%A7%D8%B5-%D9%88-%D8%B5%D8%B9%D8%A8-%D8%A7%D9%84%D8%B9%D9%84%D8%A7%D8%AC-%DA%AF%D8%A7%D9%85%DB%8C-%D8%A8%D8%B1%D8%A7%DB%8C-%DA%A9%D8%A7%D9%87%D8%B4-%D9%BE%D8%B1%D8%AF%D8%A7%D8%AE%D8%AA-%D8%A7%D8%B2-%D8%AC%DB%8C%D8%A8</guid>
    </item>
