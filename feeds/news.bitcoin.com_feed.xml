		<title>Report: Hungary Drops Criminal Penalties for Crypto After Orban&#8217;s 16-Year Rule Ends</title>
		<link>https://news.bitcoin.com/report-hungary-drops-criminal-penalties-for-crypto-after-orbans-16-year-rule-ends/</link>
		
		<dc:creator><![CDATA[Jamie Redman]]></dc:creator>
		<pubDate>Thu, 11 Jun 2026 18:20:32 +0000</pubDate>
				<category><![CDATA[News]]></category>
