		<title>Robinhood Launches AI Agent Trading for 27 Million Customers, Options and Crypto Next</title>
		<link>https://news.bitcoin.com/robinhood-launches-ai-agent-trading-for-27-million-customers-options-and-crypto-next/</link>
		
		<dc:creator><![CDATA[Jamie Redman]]></dc:creator>
		<pubDate>Wed, 27 May 2026 17:30:26 +0000</pubDate>
