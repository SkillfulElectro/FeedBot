      <category domain="http://www.nytimes.com/namespaces/keywords/des">Suits and Litigation (Civil)</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/des">Birth Control and Family Planning</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_geo">Louisiana</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_org">Food and Drug Administration</category>
      <media:content height="1799" medium="image" url="https://static01.nyt.com/images/2026/05/02/multimedia/02nat-abortion-pill-wfcp/02nat-abortion-pill-wfcp-mediumSquareAt3X.jpg" width="1800"></media:content>
      <media:credit>Hannah Yoon for The New York Times</media:credit>
